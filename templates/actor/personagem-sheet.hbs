<div class="cv-sheet cv-personagem">

  <div class="cv-zona-fixa">
    <div class="cv-topo">
      <div class="cv-retrato" data-action="edit-img" style="background-image:url('{{actor.img}}')">
        <span class="cv-retrato-corner"></span>
        <div class="cv-retrato-overlay">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="5" width="18" height="14" rx="1"></rect><circle cx="8.5" cy="10" r="1.6"></circle><path d="M21 15l-5-4-4 3.5-3-2.5-6 5"></path></svg>
          Clique para<br>trocar o retrato
        </div>
      </div>

      <div class="cv-identidade">
        <div>
          <input class="cv-nome" type="text" name="name" value="{{actor.name}}" placeholder="Nome do personagem">
          <div class="cv-sub">Fantasia Urbana Sobrenatural · A Cidade Sob o Véu</div>
        </div>
        <div class="cv-campos-id">
          <div class="cv-campo"><label>Conceito</label><input type="text" name="system.conceito" value="{{system.conceito}}" placeholder="Ex.: legista que vê demais"></div>
          <div class="cv-campo"><label>Jogador(a)</label><input type="text" name="system.jogador" value="{{system.jogador}}"></div>
          <div class="cv-campo"><label>Nível</label>
            <select name="system.nivel">
              {{#each niveis as |n|}}<option value="{{n}}" {{selecionado n ../system.nivel}}>{{n}}</option>{{/each}}
            </select>
          </div>
        </div>
      </div>

      <button type="button" class="cv-rolar-cta" data-action="rolar-livre">
        <span class="cv-rolar-dado">🎲</span>
        <span class="cv-rolar-txt">Rolar</span>
        <span class="cv-rolar-sub">Ação vs. Risco</span>
      </button>
    </div>

    <div class="cv-vitals">
      <div class="cv-vital-grp">
        <label>Estilo de Vida</label>
        <select name="system.estiloDeVida">
          {{#each estilosDeVida as |ev|}}<option value="{{ev}}" {{#if (eq ev ../system.estiloDeVida)}}selected{{/if}}>{{ev}}</option>{{/each}}
        </select>
        <button type="button" class="cv-mini-roll" data-action="rolar-estilo-vida" title="Rolar 1d20">🎲</button>
      </div>
      <div class="cv-vital-grp">
        <label>XP <span class="cv-badge">{{system.xp.atual}}/10</span></label>
        <div class="cv-xpbar">
          {{#each xpPips as |i|}}
          <div class="cv-xp-pip {{#if (lt i ../system.xp.atual)}}on{{/if}}" data-action="set-xp" data-index="{{i}}"></div>
          {{/each}}
        </div>
      </div>
      <div class="cv-vital-grp">
        <div class="cv-token {{#if system.tokenSorte}}on{{/if}}" data-action="toggle-token" title="Regra opcional (Cap. 1): ajusta 1 dado em ±1">
          <span class="cv-los-mini"></span>
          <span class="cv-tk-txt">{{#if system.tokenSorte}}Token de Sorte · disponível{{else}}Token de Sorte · gasto{{/if}}</span>
        </div>
      </div>
      <div class="cv-vital-grp cv-vital-tags">
        <span class="cv-badge">+{{totalPositivas}} / −{{totalNegativas}} Tags em jogo</span>
      </div>
    </div>
  </div>

  <div class="cv-bloco-fer">
    <div class="cv-fer-tit">Trilha de Ferimentos</div>
    <div class="cv-fer">
      {{#each ferimentosInfo as |f i|}}
      <div class="cv-fer-item {{#if (gt ../system.vida.pontos i)}}on{{/if}}" data-action="toggle-ferimento" data-index="{{i}}">
        <div class="cv-los"></div>
        <div class="cv-fer-nome">{{f.nivel}}</div>
        <div class="cv-fer-ef">{{f.efeito}}</div>
      </div>
      {{/each}}
    </div>
    <div class="cv-lista-ferimentos">
      {{#each system.vida.ferimentos as |fer i|}}
      <div class="cv-chip cv-chip-neg">
        <span class="s">−</span> {{fer.nome}} <em>({{fer.nivel}})</em>
        <button type="button" class="cv-mini" data-action="recuperar-ferimento" data-index="{{i}}" title="Recuperar este ferimento">✓ recuperar</button>
      </div>
      {{else}}
      <p class="cv-empty">Sem ferimentos.</p>
      {{/each}}
    </div>
    <div class="cv-field" style="margin-top:8px;"><label class="cv-lab">Proteção em uso (−1 dano se adequada)</label><input type="text" name="system.protecao" value="{{system.protecao}}" placeholder="Ex.: colete balístico"></div>
  </div>

  <div class="cv-tabs">
    <button type="button" class="cv-tab {{#if (eq tabAtivo "carac")}}on{{/if}}" data-action="mudar-aba" data-tab="carac">① Características</button>
    <button type="button" class="cv-tab {{#if (eq tabAtivo "anc")}}on{{/if}}" data-action="mudar-aba" data-tab="anc">② Ancestralidade</button>
    <button type="button" class="cv-tab {{#if (eq tabAtivo "arq")}}on{{/if}}" data-action="mudar-aba" data-tab="arq">③ Arquétipo</button>
    <button type="button" class="cv-tab {{#if (eq tabAtivo "ante")}}on{{/if}}" data-action="mudar-aba" data-tab="ante">④ Antecedente</button>
    <button type="button" class="cv-tab {{#if (eq tabAtivo "itens")}}on{{/if}}" data-action="mudar-aba" data-tab="itens">Equipamento &amp; Itens</button>
  </div>

  {{!-- Características --}}
  <div class="cv-painel {{#if (eq tabAtivo "carac")}}on{{/if}}">
    <div class="cv-hint">Qualidades ({{qualidades.length}})</div>
    {{#each qualidades as |t|}}{{> "cidade-sob-o-veu.tag-row" t=t cls="pos"}}{{/each}}
    <div class="cv-add-row">
      <select name="pick-qualidade">
        <option value="">— escolha —</option>
        {{#each caracteristicasPositivas as |o|}}<option value="{{o.grupo}}|{{o.nome}}">{{o.grupo}} · {{o.nome}}</option>{{/each}}
      </select>
      <button type="button" class="cv-mini" data-action="add-qualidade">+ adicionar</button>
      <button type="button" class="cv-mini" data-action="rolar-qualidade">🎲 1d20</button>
    </div>

    <div class="cv-hint" style="margin-top:14px;">Defeitos · novos podem vir da quase morte</div>
    {{#each defeitos as |t|}}{{> "cidade-sob-o-veu.tag-row" t=t cls="neg"}}{{/each}}
    <div class="cv-add-row">
      <select name="pick-defeito">
        <option value="">— escolha —</option>
        {{#each caracteristicasNegativas as |o|}}<option value="{{o.grupo}}|{{o.nome}}">{{o.grupo}} · {{o.nome}}</option>{{/each}}
      </select>
      <button type="button" class="cv-mini" data-action="add-defeito">+ adicionar</button>
      <button type="button" class="cv-mini" data-action="rolar-defeito">🎲 1d20</button>
    </div>
  </div>

  {{!-- Ancestralidade --}}
  <div class="cv-painel {{#if (eq tabAtivo "anc")}}on{{/if}}">
    <div class="cv-grid cv-g2c">
      <div>
        <label class="cv-lab">Ancestralidade atual: <strong>{{system.ancestralidadeNome}}</strong></label>
        <div class="cv-add-row">
          <select name="pick-ancestralidade">
            <option value="">— escolha —</option>
            {{#each ancestralidadeIndex as |e|}}<option value="{{e._id}}" {{#if (eq e.name ../system.ancestralidadeNome)}}selected{{/if}}>{{e.name}}</option>{{/each}}
          </select>
          <button type="button" class="cv-mini" data-action="aplicar-ancestralidade">Aplicar</button>
          <button type="button" class="cv-mini" data-action="rolar-ancestralidade">🎲 1d8</button>
        </div>
      </div>
      <div><label class="cv-lab">Definições com o mestre</label><input type="text" name="system.ancestralidadeNotas" value="{{system.ancestralidadeNotas}}"></div>
    </div>
    <div class="cv-tags-grid" style="margin-top:12px;">
      {{#each virtudes as |t|}}{{> "cidade-sob-o-veu.tag-row" t=t cls="pos"}}{{/each}}
      {{#each vulnerabilidades as |t|}}{{> "cidade-sob-o-veu.tag-row" t=t cls="neg"}}{{/each}}
    </div>
  </div>

  {{!-- Arquétipo --}}
  <div class="cv-painel {{#if (eq tabAtivo "arq")}}on{{/if}}">
    <label class="cv-lab">Arquétipo atual: <strong>{{system.arquetipoNome}}</strong></label>
    <div class="cv-add-row">
      <select name="pick-arquetipo">
        <option value="">— escolha —</option>
        {{#each arquetipoIndex as |e|}}<option value="{{e._id}}" {{#if (eq e.name ../system.arquetipoNome)}}selected{{/if}}>{{e.name}}</option>{{/each}}
      </select>
      <button type="button" class="cv-mini" data-action="aplicar-arquetipo">Aplicar</button>
      <button type="button" class="cv-mini" data-action="rolar-arquetipo">🎲 1d10</button>
    </div>

    <div class="cv-hint" style="margin-top:14px;">Especialidades ({{especialidades.length}} / nível {{system.nivel}})</div>
    {{#each especialidades as |t|}}{{> "cidade-sob-o-veu.tag-row" t=t cls="pos"}}{{/each}}
    {{#if arquetipoOptions}}
    <div class="cv-add-row">
      <select name="pick-especialidade">
        {{#each arquetipoOptions.especialidades as |o|}}<option value="{{o.i}}">{{o.nome}}</option>{{/each}}
      </select>
      <button type="button" class="cv-mini" data-action="add-especialidade">+ adicionar</button>
      <button type="button" class="cv-mini" data-action="add-especialidade" data-aleatoria="true">🎲 1d20</button>
    </div>
    {{/if}}

    <div class="cv-hint" style="margin-top:14px;">Vícios e Limitações ({{vicios.length}} / nível {{system.nivel}})</div>
    {{#each vicios as |t|}}{{> "cidade-sob-o-veu.tag-row" t=t cls="neg"}}{{/each}}
    {{#if arquetipoOptions}}
    <div class="cv-add-row">
      <select name="pick-vicio">
        {{#each arquetipoOptions.vicios as |o|}}<option value="{{o.i}}">{{o.nome}}</option>{{/each}}
      </select>
      <button type="button" class="cv-mini" data-action="add-vicio">+ adicionar</button>
      <button type="button" class="cv-mini" data-action="add-vicio" data-aleatoria="true">🎲 1d20</button>
    </div>
    {{/if}}
  </div>

  {{!-- Antecedente --}}
  <div class="cv-painel {{#if (eq tabAtivo "ante")}}on{{/if}}">
    <label class="cv-lab">Profissão atual: <strong>{{system.profissaoNome}}</strong></label>
    <div class="cv-add-row">
      <select name="pick-profissao">
        <option value="">— escolha —</option>
        {{#each profissaoIndex as |e|}}<option value="{{e._id}}" {{#if (eq e.name ../system.profissaoNome)}}selected{{/if}}>{{e.name}}</option>{{/each}}
      </select>
      <button type="button" class="cv-mini" data-action="aplicar-profissao">Aplicar</button>
      <button type="button" class="cv-mini" data-action="rolar-profissao">🎲 1d100</button>
    </div>

    <div class="cv-hint" style="margin-top:14px;">Aprendizados</div>
    {{#each aprendizados as |t|}}{{> "cidade-sob-o-veu.tag-row" t=t cls="pos"}}{{/each}}
    <button type="button" class="cv-mini" data-action="add-aprendizado">+ adicionar aprendizado narrativo</button>

    <div class="cv-hint" style="margin-top:14px;">Traumas</div>
    {{#each traumas as |t|}}{{> "cidade-sob-o-veu.tag-row" t=t cls="neg"}}{{/each}}
    <div class="cv-add-row">
      <select name="pick-trauma">
        <option value="">— escolha —</option>
        {{#each traumaIndex as |e|}}<option value="{{e._id}}">{{e.name}}</option>{{/each}}
      </select>
      <button type="button" class="cv-mini" data-action="aplicar-trauma">Aplicar</button>
      <button type="button" class="cv-mini" data-action="rolar-trauma">🎲 1d100</button>
    </div>
    <button type="button" class="cv-mini" data-action="add-trauma-narrativo">+ adicionar trauma narrativo</button>
  </div>

  {{!-- Equipamento & Itens --}}
  <div class="cv-painel {{#if (eq tabAtivo "itens")}}on{{/if}}">
    <div class="cv-hint">Itens Mágicos ou Aprimorados (nível = nº de Dádivas)</div>
    {{#each itensMagicos as |it|}}
    <div class="cv-item-card" data-item-id="{{it.id}}">
      <div class="cv-item-top">
        <img src="{{it.img}}" class="cv-item-img" data-action="edit-item">
        <span class="cv-item-nome" data-action="edit-item">{{it.name}}</span>
        <span class="cv-badge">Nível {{it.system.nivel}}</span>
        <button type="button" class="cv-mini" data-action="edit-item">✎ editar</button>
        <button type="button" class="cv-mini" data-action="delete-item">✕ remover</button>
      </div>
    </div>
    {{else}}
    <p class="cv-empty">Nenhum item mágico ou aprimorado.</p>
    {{/each}}
    <button type="button" class="cv-mini" data-action="add-mitem">+ adicionar item</button>

    <div class="cv-grid cv-g2c" style="margin-top:20px;">
      <div><label class="cv-lab">Equipamento &amp; bens</label><textarea name="system.equipamento" rows="4">{{system.equipamento}}</textarea></div>
      <div><label class="cv-lab">Aliados, inimigos &amp; notas</label><textarea name="system.notas" rows="4">{{system.notas}}</textarea></div>
    </div>
  </div>

</div>
