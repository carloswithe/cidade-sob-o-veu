{"_id":"rRuqrtEORQ5tL2ZH","name":"Agente da Divisão Velada","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Ameaça","vitalidade":{"max":2,"atual":2},"categoriaArma":"III","protecao":"Colete (−1 contra balas e lâminas)","comoAparece":"Depois do incidente, antes da imprensa. Faz perguntas educadas com respostas já decididas.","comoLuta":"Nunca sozinho e nunca às cegas — cerca, isola, oferece o acordo uma única vez."},"items":[{"_id":"4EsivGlo45LCa3GA","name":"Treinamento de Elite","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"wyeQ9Pb1cY0oSR8n","name":"Autoridade que Não Existe Oficialmente","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"c8RnfnN1yZD6Xl2v","name":"Preso ao Protocolo","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — burocracia e cadeia de comando o engessam."}}]}
