{"_id":"0PenQ0HR4uOvli1B","name":"Demônio Manifestado","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Colosso","vitalidade":{"max":6,"atual":6},"categoriaArma":"IV","protecao":"","descricao":"Não deveria estar deste lado. Alguém abriu a porta — e a conta chegou para a cidade inteira."},"items":[{"_id":"YLJ9wZWjc1qwhnhh","name":"Carne do Abismo","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"vzVhcYv3vVtTg4wh","name":"Terror Ambulante","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"qC9OXiaZ8sQlD8xN","name":"Astúcia Milenar","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"6mnYmI6FpW7neMx0","name":"Preso ao Nome Verdadeiro","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — quem o souber pode bani-lo ou vinculá-lo."}}]}
{"_id":"0v0vEnZw5gVVJom6","name":"Zumbi Recém-Erguido","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Capanga","vitalidade":{"max":1,"atual":1},"categoriaArma":"II","protecao":"","comoAparece":"Raramente sozinho — e sempre a serviço de alguém. Zumbi é sintoma; o necromante é a doença.","comoLuta":"Em massa (use a regra de Bando). Ignora ferimentos que parariam um vivo."},"items":[{"_id":"rnqjZ2U2RO1RRbBD","name":"Não Sente Dor","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"RppJIDoSwhmVPfwp","name":"Agarra e Não Solta","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"7FSDiaVLuGXToQhz","name":"Lento e Previsível","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza."}}]}
{"_id":"1IdgCOXPiQumg2i0","name":"Fugitivo do Programa","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Ameaça","vitalidade":{"max":2,"atual":2},"categoriaArma":"III","protecao":"","comoAparece":"Metade vítima, metade arma. O Programa o quer de volta — e quem o ajudar entra na mesma lista.","comoLuta":"Rápido e econômico, sempre perto da rota de fuga. Não quer matar: quer continuar livre."},"items":[{"_id":"YhuFc6yfLR9RegfC","name":"Reflexos Aprimorados","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"G91aQVoZUjsRXkiu","name":"Sente Campos Eletrônicos","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"6NwoZ9udYv50rHLW","name":"Manutenção Atrasada","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — os implantes falham sob dano elétrico ou interferência."}}]}
{"_id":"1w2xZxBu2YQI1s4s","name":"Diabrete de Contrato","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Capanga","vitalidade":{"max":1,"atual":1},"categoriaArma":"I","protecao":"","comoAparece":"Atrás de pequenas tragédias em série: o freio que falha, o contrato que some, o incêndio \"elétrico\".","comoLuta":"Não luta — atrapalha. É mais útil capturado do que morto: diabretes sabem para quem trabalham."},"items":[{"_id":"i7G8VufkeR0ctURe","name":"Pequeno e Escorregadio","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"TzpJvgIsHki7Lzbj","name":"Semeia Infortúnios","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"GtTAeLDJbAP4c62E","name":"Covarde Fundamental","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — qualquer demonstração de força o faz negociar."}}]}
{"_id":"AGyNc3pHtz5kVya2","name":"Bruxa do Conjunto Habitacional","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Adversário à Altura","vitalidade":{"max":4,"atual":4},"categoriaArma":"II","protecao":"","comoAparece":"A senhora prestativa do bloco C. Todo mundo deve um favor a ela — e ela cobra.","comoLuta":"Não luta: já lutou. A praga foi lançada semana passada; o grupo só está descobrindo agora."},"items":[{"_id":"DCtJjrVP4D0wBXxV","name":"Pragas Lançadas à Distância","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"k3ozdzR6YnXgZN68","name":"Olhos em Cada Vizinho","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"gNKlzGFcZxssMjI3","name":"Território Enfeitiçado","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"QbCQUJlqCHL07ToO","name":"Presa aos Próprios Fetiches","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — destrua os amuletos escondidos e o poder desaba."}}]}
{"_id":"GAvO5OS5UyEM8hbU","name":"Corpo-Seco","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Adversário à Altura","vitalidade":{"max":4,"atual":4},"categoriaArma":"III","protecao":"Pele como couro velho (−1 contra lâminas e impacto)","comoAparece":"O folclore diz que foi gente ruim demais para a terra aceitar. Agora vive nas árvores do parque velho, nos vãos do viaduto — e desce quando escurece.","comoLuta":"Emboscada de cima, força bruta, e uma resistência anormal a tudo que não seja sagrado."},"items":[{"_id":"fp058BlTLcWS5IOA","name":"A Terra o Rejeitou","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"HeT2B7LBs3NT3YHf","name":"Fedor que Anuncia","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"OfQX5SRqzCzTjMgH","name":"Arde ao Ser Benzido","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — água benta, oração e solo consagrado queimam-no de verdade."}}]}
{"_id":"HZqF4U7PzOrBZSer","name":"Gólem de Concreto","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Colosso","vitalidade":{"max":5,"atual":5},"categoriaArma":"III","protecao":"Corpo de concreto (−1 contra tudo, exceto contra a fraqueza)","descricao":"Categoria IV se arremessar estrutura.","comoAparece":"Obras embargadas onde operários somem, e uma estátua que ninguém lembra de ter erguido.","comoLuta":"Devagar, inexorável e sem malícia — cumpre a ordem gravada nele, literal até o desastre."},"items":[{"_id":"dxpPsWA75xnyfPTS","name":"Feito da Própria Cidade","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"YxOPEkwOTztPUR51","name":"Imparável em Linha Reta","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"XeTB2Y1v9PlmVleA","name":"O Sigilo na Nuca","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — apagar ou corromper a inscrição que o anima o desliga."}}]}
{"_id":"JceKD0ioNrIdbZZR","name":"Carniçal dos Túneis","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Ameaça","vitalidade":{"max":2,"atual":2},"categoriaArma":"II","protecao":"","descricao":"Come o que acha nos subterrâneos. Ultimamente, anda achando gente."},"items":[{"_id":"8xQgarHE8oad00R4","name":"Faro de Carne","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"pwtnB7QFft554AM8","name":"Rápido no Escuro","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"Pz4nE1xS0U6YblxC","name":"A Luz o Cega","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza."}}]}
{"_id":"Pb2PuvLr7QQP5X3k","name":"Mercenária do Submundo","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Ameaça","vitalidade":{"max":2,"atual":2},"categoriaArma":"III","protecao":"Colete (−1 contra balas e lâminas)","descricao":"Não é pessoal. Nunca é. A não ser que você aumente a oferta."},"items":[{"_id":"pDzQnmzWyYn6PXzA","name":"Fria e Profissional","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"IIPYbVVEEb7iMbOq","name":"Conhece os Becos","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"YScNS7daO3n9quOy","name":"Só Luta por Contrato","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — dinheiro renegocia tudo."}}]}
{"_id":"Ps2KoyAoP93rsG9r","name":"Sacerdote do Culto do Abismo","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Adversário à Altura","vitalidade":{"max":3,"atual":3},"categoriaArma":"III","protecao":"","comoAparece":"Por trás de desaparecimentos com padrão: mesma lua, mesmo perfil de vítima, mesmo símbolo riscado por perto.","comoLuta":"Atrás de uma parede de fiéis, terminando o que começou. O combate é contra o relógio da litania."},"items":[{"_id":"clGSWdpB8QDf3Eh0","name":"Rebanho Fanático","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"ZlGEgl51ZaGTvvzX","name":"Litania que Enfraquece","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"fsyVQ3BmWWkOECXR","name":"Nada Sem o Ídolo","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — separado do ícone do culto, seu poder míngua."}}]}
{"_id":"QHmKKllU0rGN23ZO","name":"Alfa da Alcateia do Porto","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Colosso","vitalidade":{"max":5,"atual":5},"categoriaArma":"III","protecao":"Couro da fera (−1 contra impacto e lâminas)","descricao":"Duas décadas mandando no cais. Já enterrou todos que tentaram mudar isso."},"items":[{"_id":"NdFELko8zWSzPczY","name":"Fúria Colossal","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"u209cQimwor7wBvr","name":"Sentidos de Predador","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"vidDOx8Xo9iZvAaS","name":"Território Conhecido","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"CKGQnEiL7Mwo21zO","name":"A Prata o Queima","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — anula a proteção e fere fundo."}}]}
{"_id":"d7QmdA3plZEBxdWP","name":"Sanguessuga do Mercado","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Adversário à Altura","vitalidade":{"max":4,"atual":4},"categoriaArma":"III","protecao":"","comoAparece":"No topo do prédio que comprou com o dinheiro de três vidas passadas. Oferece emprego, patrocínio, eternidade.","comoLuta":"Por procuração — advogados, seguranças, crias. Se forçado ao corpo a corpo, o terno esconde um predador de duzentos anos."},"items":[{"_id":"g91zgfbDzM2lmuhD","name":"Fascínio Predatório","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"6V17zYXFvfGWNF4w","name":"Recursos de Sobra","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"DMkobDUeKTwQ7iN8","name":"Séculos de Paciência","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"Qu2X3kJrmp3bohNF","name":"As Regras da Hospitalidade","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — não entra sem convite, e um convite revogado o expulsa."}}]}
{"_id":"dGiKnr65TWIhaHql","name":"Espectro Vingativo","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Ameaça","vitalidade":{"max":2,"atual":2},"categoriaArma":"II","protecao":"","comoAparece":"Temperatura caindo, eletrônicos falhando, e a mesma silhueta no mesmo horário — sempre onde a injustiça aconteceu.","comoLuta":"Aparece e some, mira quem carrega culpa. Sem resolver (ou destruir) a âncora, o combate é só fuga organizada."},"items":[{"_id":"sW762wsWtcQBU3oM","name":"Incorpóreo","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"EoewIESEAeEQaz8P","name":"Atravessa Paredes","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"9UYc7lT9FSmmrGYu","name":"Preso ao Objeto da Morte","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — armas comuns não o ferem; destrua ou consagre a âncora."}}]}
{"_id":"hjEwh12U1SbGakBt","name":"Cultista do Círculo Raso","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Capanga","vitalidade":{"max":1,"atual":1},"categoriaArma":"II","protecao":"","descricao":"Descartável até para o próprio culto. O perigo real é o que ele está tentando invocar."},"items":[{"_id":"skbqMdSMl40wQP9m","name":"Fanatismo Cego","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"1nFsDYuEOejQuNyA","name":"Amador Nervoso","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — entra em pânico quando o ritual desanda."}}]}
{"_id":"joYHlrbyfDJArN2H","name":"Segurança de Boate","type":"adversario","img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"porte":"Capanga","vitalidade":{"max":1,"atual":1},"categoriaArma":"I","protecao":"","descricao":"Um muro de músculos na porta errada. Perigoso em grupo, contornável na lábia."},"items":[{"_id":"hsuh70bRYVS2h3oX","name":"Corpulento","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"positiva","origem":"caracteristica"}},{"_id":"IlGkeiX2fyqFNIbB","name":"Segue o Protocolo","type":"tag","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{},"system":{"polaridade":"negativa","origem":"caracteristica","descricao":"Fraqueza — previsível, negociável com hierarquia."}}]}
